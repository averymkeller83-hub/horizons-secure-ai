# Horizons Secure AI — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === API Gateway ===
API_PORT=8000
LOG_LEVEL=info

# === Ollama (Local LLM) ===
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# === PostgreSQL ===
POSTGRES_PORT=5432
POSTGRES_DB=horizons
POSTGRES_USER=horizons
POSTGRES_PASSWORD=change_me_in_production

# === Redis (Task Queue) ===
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# === Database URL (used by API and migration scripts) ===
DATABASE_URL=postgresql+asyncpg://horizons:change_me_in_production@localhost:5432/horizons
